digraph ModuleDependencyGraph {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor="#e8f4fd", fontname="Helvetica"];
    edge [color="#666666"];

    feature_settings_impl [fillcolor="#fbbf24", style="filled,bold"];
    feature_settings_impl -> feature_settings_impl [color="#ef4444", style=bold];
    feature_settings_impl -> core_ui [];
    feature_settings_impl -> core_designsystem [];
    feature_settings_impl -> core_data [];
    feature_settings_impl -> core_testing [];
}
